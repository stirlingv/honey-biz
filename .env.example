# Bear Creek Apiaries - Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# Django Settings
# =============================================================================
# Generate a new secret key for production:
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=your-secret-key-here

# Set to False in production!
DEBUG=True

# Add your domain in production (e.g., bcapiaries.com,www.bcapiaries.com)
ALLOWED_HOSTS=localhost,127.0.0.1

# =============================================================================
# Email / SMS Notifications
# =============================================================================
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-gmail@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@bcapiaries.com

# Optional: admin email fallback (set if email is configured)
ADMIN_NOTIFICATION_EMAIL=moms-email@example.com

# =============================================================================
# Slack Notifications (primary alert channel)
# =============================================================================
# 1. Create a free Slack workspace at slack.com
# 2. Go to api.slack.com/apps → Create New App → From scratch
# 3. Enable Incoming Webhooks → Add New Webhook to Workspace → pick a channel
# 4. Copy the webhook URL here
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# =============================================================================
# AWS S3 (product image storage in production)
# =============================================================================
USE_S3=False
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_STORAGE_BUCKET_NAME=your-bucket-name
AWS_S3_REGION_NAME=us-east-1

# =============================================================================
# Production Deployment Checklist
# =============================================================================
# Before going live, ensure:
# [ ] DEBUG=False
# [ ] New DJANGO_SECRET_KEY generated
# [ ] ALLOWED_HOSTS set to your domain
# [ ] SSL/HTTPS enabled on your hosting provider
# [ ] Database backups configured
