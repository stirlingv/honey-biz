# Bear Creek Apiaries - Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# Django Settings
# =============================================================================
# Generate a new secret key for production:
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=your-secret-key-here

# Set to False in production!
DEBUG=True

# Add your domain in production (e.g., bcapiaries.com,www.bcapiaries.com)
ALLOWED_HOSTS=localhost,127.0.0.1

# =============================================================================
# Square Payment Integration
# =============================================================================
# Get these from https://developer.squareup.com → Applications → your app

# Access token (use sandbox token for dev, production token for live)
SQUARE_ACCESS_TOKEN=your-access-token-here

# Location ID — found in Square Dashboard → Locations
SQUARE_LOCATION_ID=your-location-id-here

# Change to 'production' when going live
SQUARE_ENVIRONMENT=sandbox

# Webhook signature key — found in Square Dashboard → Webhooks → your endpoint
# Used to verify that webhook requests genuinely come from Square
SQUARE_WEBHOOK_SIGNATURE_KEY=your-webhook-signature-key-here

# =============================================================================
# Email / SMS Notifications
# =============================================================================
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-gmail@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@bcapiaries.com

# Development notification targets
DEV_SMS_NOTIFICATION_EMAIL=your-phone@vtext.com
DEV_ADMIN_NOTIFICATION_EMAIL=your-email@example.com

# Production notification targets (mom's accounts)
SMS_NOTIFICATION_EMAIL=moms-phone@vtext.com
ADMIN_NOTIFICATION_EMAIL=moms-email@example.com

# =============================================================================
# AWS S3 (product image storage in production)
# =============================================================================
USE_S3=False
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_STORAGE_BUCKET_NAME=your-bucket-name
AWS_S3_REGION_NAME=us-east-1

# =============================================================================
# Production Deployment Checklist
# =============================================================================
# Before going live, ensure:
# [ ] DEBUG=False
# [ ] New DJANGO_SECRET_KEY generated
# [ ] ALLOWED_HOSTS set to your domain
# [ ] SQUARE_ENVIRONMENT=production
# [ ] SQUARE_ACCESS_TOKEN set to production token (not sandbox)
# [ ] SQUARE_WEBHOOK_SIGNATURE_KEY set from Square Dashboard → Webhooks
# [ ] Webhook URL registered in Square Dashboard: https://yourdomain.com/webhooks/square/
#     Events to subscribe: payment.completed, payment.failed
# [ ] SSL/HTTPS enabled on your hosting provider
# [ ] Database backups configured
